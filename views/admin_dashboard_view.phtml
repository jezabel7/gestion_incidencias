<script>
const listaMaestraTecnicos = [
    <?php foreach($tecnicos as $t): ?>
    {
        id: "<?= $t['id_usuario'] ?>",
        nombre: "<?= $t['nombre'] ?> <?= $t['apellido'] ?>",
        predio: "<?= $t['id_predio'] ?>",
        nombres_espec: "<?= $t['nombres_especialidades'] ?? 'General' ?>",
        ids_espec: "<?= $t['ids_especialidades'] ?>".split(',') 
    },
    <?php endforeach; ?>
];

function abrirModal(id, idPredioReporte, idsCategoriasReporte) {
    document.getElementById('modal-id-text').innerText = id;
    document.getElementById('input-id-reporte').value = id;
    
    const selectTec = document.getElementById('select-tecnicos');
    selectTec.innerHTML = '<option value="">-- Seleccionar Técnico --</option>';
    
    const categoriasReporte = String(idsCategoriasReporte).split(',');
    let especialistasEncontrados = 0;

    listaMaestraTecnicos.forEach(tecnico => {
        const mismoPredio = String(tecnico.predio) === String(idPredioReporte);
        const esEspecialista = tecnico.ids_espec.some(idEsp => categoriasReporte.includes(String(idEsp).trim()));

        if (mismoPredio && esEspecialista) {
            const el = document.createElement('option');
            el.value = tecnico.id;
            el.textContent = `${tecnico.nombre} (${tecnico.nombres_espec})`;
            selectTec.appendChild(el);
            especialistasEncontrados++;
        }
    });

    if (especialistasEncontrados === 0) {
        listaMaestraTecnicos.forEach(tecnico => {
            if (String(tecnico.predio) === String(idPredioReporte)) {
                const el = document.createElement('option');
                el.value = tecnico.id;
                el.textContent = `${tecnico.nombre} (General)`;
                selectTec.appendChild(el);
            }
        });
    }

    document.getElementById('select-estado').value = "1";
    controlarCampos();
    document.getElementById('modalGestion').style.display = "block";
}

function cerrarModal() {
    document.getElementById('modalGestion').style.display = "none";
}

function controlarCampos() {
    const estado = document.getElementById('select-estado').value;
    const seccion = document.getElementById('seccion-tecnico');
    const select = document.getElementById('select-tecnicos');

    const mostrar = (estado == "2" || estado == "3");
    seccion.style.display = mostrar ? "block" : "none";
    select.required = mostrar;
}
</script>

