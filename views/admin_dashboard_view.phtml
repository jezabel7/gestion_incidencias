<script>
// 1. Guardamos los técnicos en "memoria" de JS al cargar la página
const listaMaestraTecnicos = [
    <?php foreach($tecnicos as $t): ?>
    {
        id: "<?= $t['id_usuario'] ?>",
        nombre: "<?= $t['nombre'] ?> <?= $t['apellido'] ?>",
        predio: "<?= $t['id_predio'] ?>",
        nombres_espec: "<?= $t['nombres_especialidades'] ?? 'General' ?>",
        // Convertimos la cadena "1,2,3" en un verdadero array de JavaScript
        ids_espec: "<?= $t['ids_especialidades'] ?>".split(',') 
    },
    <?php endforeach; ?>
];

function abrirModal(id, idPredioReporte, idsCategoriasReporte) {
    // 🚩 Debug: Verificamos qué listas estamos recibiendo
    console.log("Categorías del reporte:", idsCategoriasReporte);

    document.getElementById('modal-id-text').innerText = id;
    document.getElementById('input-id-reporte').value = id;
    
    const selectTec = document.getElementById('select-tecnicos');
    selectTec.innerHTML = '<option value="">-- Seleccionar Técnico --</option>';
    
    // Convertimos la lista del reporte en un array: "1,8" -> ["1", "8"]
    const categoriasReporte = String(idsCategoriasReporte).split(',');

    let especialistasEncontrados = 0;

    listaMaestraTecnicos.forEach(tecnico => {
        const mismoPredio = String(tecnico.predio) === String(idPredioReporte);
        
        // Verificamos si existe AL MENOS una coincidencia entre las listas
        // (Si el técnico sabe hacer ALGO de lo que el reporte pide)
        const esEspecialista = tecnico.ids_espec.some(idEsp => 
            categoriasReporte.includes(String(idEsp).trim())
        );

        if (mismoPredio && esEspecialista) {
            const el = document.createElement('option');
            el.value = tecnico.id;
            el.textContent = `${tecnico.nombre} (${tecnico.nombres_espec})`;
            selectTec.appendChild(el);
            especialistasEncontrados++;
        }
    });

    // Plan B: Si no hay nadie específico, cargar a todos los del predio
    if (especialistasEncontrados === 0) {
        console.warn("Sin especialistas exactos. Cargando personal del predio...");
        listaMaestraTecnicos.forEach(tecnico => {
            if (String(tecnico.predio) === String(idPredioReporte)) {
                const el = document.createElement('option');
                el.value = tecnico.id;
                el.textContent = `${tecnico.nombre} (${tecnico.nombres_espec}) - Gral`;
                selectTec.appendChild(el);
            }
        });
    }

    document.getElementById('select-estado').value = "1";
    controlarCampos();
    document.getElementById('modalGestion').style.display = "block";
}

function cerrarModal() {
    document.getElementById('modalGestion').style.display = "none";
}

/**
 * Controla la visibilidad del técnico según el estado (Asignado/En Proceso)
 */
function controlarCampos() {
    const estado = document.getElementById('select-estado').value;
    const seccionTecnico = document.getElementById('seccion-tecnico');
    const selectTecnicos = document.getElementById('select-tecnicos');

    // Mostramos el técnico solo si el estado es 2 (Asignado) o 3 (En Proceso)
    if (estado == "2" || estado == "3") {
        seccionTecnico.style.display = "block";
        selectTecnicos.required = true;
    } else {
        seccionTecnico.style.display = "none";
        selectTecnicos.required = false;
    }
}
</script>

