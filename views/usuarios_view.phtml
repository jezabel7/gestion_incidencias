<script>
    function abrirModal() { document.getElementById('modalUsuario').style.display = "block"; }
    function cerrarModal() { document.getElementById('modalUsuario').style.display = "none"; document.querySelector('form').reset(); }
    window.onclick = function(event) { if (event.target == document.getElementById('modalUsuario')) { cerrarModal(); } }
</script>

